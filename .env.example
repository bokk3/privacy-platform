# ---------------------------------------------------------------------------
# Privacy Platform — environment configuration template
# Copy to .env and fill in real values. Never commit the real .env file.
# ---------------------------------------------------------------------------

# --- App ---
NODE_ENV=development
APP_NAME="Privacy Platform"
APP_URL=http://localhost:5173
API_URL=http://localhost:4000
API_PORT=4000
LOG_LEVEL=info

# --- PostgreSQL (used directly by docker-compose and by Prisma) ---
POSTGRES_USER=privacy_app
POSTGRES_PASSWORD=change_me_dev_only
POSTGRES_DB=privacy_platform
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL="postgresql://privacy_app:change_me_dev_only@postgres:5432/privacy_platform?schema=public"

# --- Redis (BullMQ + session/rate-limit store) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL="redis://redis:6379"

# --- JWT / Auth ---
# Generate strong random secrets, e.g. `openssl rand -base64 64`
JWT_ACCESS_SECRET=replace_with_64_byte_random_string
JWT_REFRESH_SECRET=replace_with_a_different_64_byte_random_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
COOKIE_SECRET=replace_with_another_random_string

# --- Password hashing / encryption ---
ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1
# 32-byte (64 hex char) key used for AES-256-GCM field encryption (PII at rest)
FIELD_ENCRYPTION_KEY=replace_with_64_hex_characters_0123456789abcdef0123456789abcdef

# --- Email (Nodemailer) ---
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace_me
SMTP_PASSWORD=replace_me
SMTP_FROM_NAME="Privacy Platform"
SMTP_FROM_EMAIL=no-reply@example.com

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# --- Stripe Billing ---
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_ID=price_replace_me

# --- Playwright / broker automation ---
PLAYWRIGHT_HEADLESS=true
BROKER_JOB_CONCURRENCY=3
BROKER_JOB_TIMEOUT_MS=45000

# --- CORS ---
CORS_ORIGIN=http://localhost:5173
